<article class="feed-inner" data-url="{{url}}" data-title="{{title}}">
  <div class="feed-wrapper">
    <span class="feed-emoji" aria-hidden="true">{{#has tag="lakritze"}}🐈‍⬛{{else}}{{#has tag="lakritze"}}🐈‍⬛{{else}}{{#has tag="lakritz"}}🐈‍⬛{{else}}{{#has tag="katze"}}🐈‍⬛{{else}}{{#has tag="longpost"}}📖{{else}}{{#has tag="unterwegs"}}🧳{{else}}{{#has tag="notes"}}📝{{else}}{{#has tag="rennrad"}}🚲{{else}}{{#has tag="rennrad"}}🚲{{else}}{{#has tag="linux"}}⌨️{{else}}{{#has tag="musique"}}🎵{{else}}{{#has tag="lyrik"}}✒️{{else}}{{#has tag="software"}}💻{{else}}{{#has tag="environment"}}🌿{{else}}{{#has tag="home"}}🏠{{else}}{{#has tag="reading"}}📚{{else}}{{#has tag="food"}}🍳{{else}}{{#has tag="tech"}}⚙️{{else}}·{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}</span>
    <h2 class="body-1 feed-title">{{title}}{{#unless title}}{{excerpt words="8"}}{{/unless}}</h2>
    {{#if title}}{{#if excerpt}}<div class="feed-excerpt">{{excerpt words="12"}}</div>{{/if}}{{/if}}
    <div class="dot-spacer"></div>
    <div class="feed-right">
      <time class="feed-calendar" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM 'YY"}}</time>
      <div class="feed-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true"><path d="M5.333 14.667v2.667h16L14 24.667l1.893 1.893L26.453 16 15.893 5.44 14 7.333l7.333 7.333h-16z"/></svg></div>
    </div>
  </div>
  {{#if excerpt}}<div class="feed-sub">{{excerpt words="22"}}</div>{{/if}}
  <a class="u-permalink" href="{{url}}" aria-label="{{title}}{{#unless title}}Read post{{/unless}}"></a>
</article>
