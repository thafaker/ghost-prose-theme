{
  "name": "prose-version-v3",
  "description": "A clean text-focused microblog theme for Ghost 6",
  "version": "3.0.0",
  "engines": { "ghost": ">=6.0.0" },
  "license": "MIT",
  "author": { "email": "jan.montag@googlemail.com" },
  "config": {
    "posts_per_page": 20,
    "card_assets": true,
    "image_sizes": {
      "xs": { "width": 150 },
      "s":  { "width": 400 },
      "m":  { "width": 720 },
      "l":  { "width": 1200 }
    },
    "custom": {
      "content_width": {
        "type": "select",
        "options": ["520px", "640px", "920px"],
        "default": "640px"
      },
      "footer_text": {
        "type": "text",
        "default": ""
      }
    }
  }
}
