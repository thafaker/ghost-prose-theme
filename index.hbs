    </a>
    <a class="tag-emoji-link"
      href="/tag/katze/" 
      aria-label="Katze"
      data-tooltip="Alles über Lakritz die Katz">
		  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-paw-print-icon lucide-paw-print"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
		</a>
    <a class="tag-emoji-link" 
      href="/tag/linux/" 
      aria-label="Linux"
      data-tooltip="Texte über Linux, Computer und Hyprland">
	      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-keyboard-icon lucide-keyboard"><path d="M10 8h.01"/><path d="M12 12h.01"/><path d="M14 8h.01"/><path d="M16 12h.01"/><path d="M18 8h.01"/><path d="M6 8h.01"/><path d="M7 16h10"/><path d="M8 12h.01"/><rect width="20" height="16" x="2" y="4" rx="2"/></svg>
		</a>
    <a class="tag-emoji-link" 
      href="/tag/unterwegs/" 
      aria-label="Unterwegs"
      data-tooltip="Hier geht es um meine Ausflüge">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plane-icon lucide-plane"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
    </a>
		<a class="tag-emoji-link" 
      href="/tag/pictures/" 
      aria-label="Pictures"
      data-tooltip="Meine Beiträge mit Fotos">
		  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera-icon lucide-camera"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/></svg>
		</a>
    <a class="tag-emoji-link"
    href="/tag/musique/"
    aria-label="Musique"
    data-tooltip="Alles mit Musik">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-music-icon lucide-music"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
    </a>
    <a class="tag-emoji-link"
      href="/tag/rennrad/"
      aria-label="Rennrad"
      data-tooltip="Meine Rennrad-Liebe">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bike-icon lucide-bike"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>
    </a>
    <a class="tag-emoji-link"
      href="/tag/notes/"
      aria-label="Notes"
      data-tooltip="Meine kurzen Notizen">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-notebook-pen-icon lucide-notebook-pen"><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/><path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/></svg>
    </a>
    </nav>
  </header>

  <div class="gh-feed">
    {{#foreach posts}}
      <article class="feed post {{post_class}}">
        {{> "post-card"}}
      </article>
    {{else}}
      <p style="color:var(--color-text-faint);padding:2rem 0;">Noch keine Artikel.</p>
    {{/foreach}}
  </div>

  <div id="hover-preview" class="hover-preview" aria-hidden="true"></div>

  {{#if @site.members_enabled}}
    <div class="subscription-wrapper">
      <p class="subscribe-title">Subscribe, um bei neuen Artikeln benachrichtigt zu werden.</p>
      <form class="form-wrapper" data-members-form>
        <input class="auth-email" type="email" data-members-email placeholder="Deine E-Mail" required autocomplete="email">
        <button class="button-primary" type="submit">Subscribe</button>
      </form>
    </div>
  {{/if}}
</div>

{{#if pagination}}
  <nav class="pagination">
    {{#if pagination.prev}}<a href="{{page_url pagination.prev}}">&larr; Newer</a>{{else}}<span></span>{{/if}}
    <span>Page {{pagination.page}} of {{pagination.pages}}</span>
    {{#if pagination.next}}<a href="{{page_url pagination.next}}">Older &rarr;</a>{{else}}<span></span>{{/if}}
  </nav>
{{/if}}
