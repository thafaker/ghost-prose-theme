{{!< default}}
<div class="section-container">
  <header class="feed-header">
    <h2 class="section-title">Writing</h2>

    <nav class="tag-emoji-nav" aria-label="Tag navigation">
      <a class="tag-emoji-link" href="/tag/longpost/" aria-label="Longposts">📖</a>
      <a class="tag-emoji-link" href="/tag/katze/" aria-label="Katze">🐈‍⬛</a>
      <a class="tag-emoji-link" href="/tag/linux/" aria-label="Linux">⌨️</a>
      <a class="tag-emoji-link" href="/tag/unterwegs/" aria-label="Unterwegs">🧳</a>
      <a class="tag-emoji-link" href="/tag/pictures/" aria-label="Pictures">📷</a>
      <a class="tag-emoji-link" href="/tag/musique/" aria-label="Musique">🎵</a>
      <a class="tag-emoji-link" href="/tag/rennrad/" aria-label="Rennrad">🚲</a>
      <a class="tag-emoji-link" href="/tag/notes/" aria-label="Notes">📝</a>
    </nav>
  </header>

  <div class="gh-feed">
    {{#foreach posts}}
      <article class="feed post {{post_class}}">
        {{> "post-card"}}
      </article>
    {{else}}
      <p style="color:var(--color-text-faint);padding:2rem 0;">Noch keine Artikel.</p>
    {{/foreach}}
  </div>

  <div id="hover-preview" class="hover-preview" aria-hidden="true"></div>

  {{#if @site.members_enabled}}
    <div class="subscription-wrapper">
      <p class="subscribe-title">Subscribe, um bei neuen Artikeln benachrichtigt zu werden.</p>
      <form class="form-wrapper" data-members-form>
        <input class="auth-email" type="email" data-members-email placeholder="Deine E-Mail" required autocomplete="email">
        <button class="button-primary" type="submit">Subscribe</button>
      </form>
    </div>
  {{/if}}
</div>

{{#if pagination}}
  <nav class="pagination">
    {{#if pagination.prev}}<a href="{{page_url pagination.prev}}">&larr; Newer</a>{{else}}<span></span>{{/if}}
    <span>Page {{pagination.page}} of {{pagination.pages}}</span>
    {{#if pagination.next}}<a href="{{page_url pagination.next}}">Older &rarr;</a>{{else}}<span></span>{{/if}}
  </nav>
{{/if}}
