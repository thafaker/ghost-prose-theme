{{!< default}}
<div class="section-container">
  <header class="feed-header">
    <h2 class="section-title">Writing Topics</h2>
    <nav class="tag-emoji-nav" aria-label="Tag navigation">
      <!-- all icons from https://lucide.dev/icons/?focus -->
