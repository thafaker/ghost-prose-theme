{{!< default}}
<header class="archive-header">
  <div class="archive-label">Tag</div>
  
  {{#tag}}
  <h1 class="archive-title"># {{name}}</h1>
  {{/tag}}
  
  {{#if description}}<p class="archive-description">{{description}}</p>{{/if}}
  <span class="archive-count">{{pagination.total}} posts</span>
</header>
<div class="gh-feed">
  {{#foreach posts}}
    <article class="feed post {{post_class}}">{{> "post-card"}}</article>
  {{/foreach}}
</div>

<div id="hover-preview" class="hover-preview" aria-hidden="true"></div>
{{#if pagination}}
  <nav class="pagination">
    {{#if pagination.prev}}<a href="{{page_url pagination.prev}}">&larr; Newer</a>{{else}}<span></span>{{/if}}
    <span>Page {{pagination.page}} of {{pagination.pages}}</span>
    {{#if pagination.next}}<a href="{{page_url pagination.next}}">Older &rarr;</a>{{else}}<span></span>{{/if}}
  </nav>
{{/if}}
