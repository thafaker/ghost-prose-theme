{{!< default}}
<main class="site-main">
{{#post}}
  <article class="post-full {{post_class}}">
    <header class="post-full-header">
      {{#if tags}}
        <div class="post-full-tags">
          {{#foreach tags}}<a class="post-full-tag" href="{{url}}">{{name}}</a>{{/foreach}}
        </div>
      {{/if}}
      {{#if title}}<h1 class="post-full-title">{{title}}</h1>{{/if}}
      <div class="post-full-meta">
        {{#foreach authors}}<span class="author-name">{{name}}</span><span class="sep">&middot;</span>{{/foreach}}
        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMMM YYYY"}}</time>
        <span class="sep">&middot;</span>
        <span data-reading-time="true"></span>
      </div>
    </header>
    {{#if feature_image}}
      <figure class="post-full-image">
        <img src="{{img_url feature_image size="l"}}" srcset="{{img_url feature_image size="m"}} 720w, {{img_url feature_image size="l"}} 1200w" sizes="(max-width:680px) 100vw, 640px" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" decoding="async">
        {{#if feature_image_caption}}<figcaption>{{feature_image_caption}}</figcaption>{{/if}}
      </figure>
    {{/if}}
    {{> "content"}}
    {{#foreach authors}}
      <aside class="author-box">
        {{#if profile_image}}<img class="author-box-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}" loading="lazy">{{else}}<div class="author-box-placeholder">✍</div>{{/if}}
        <div>
          <div class="author-box-name">{{name}}</div>
          {{#if bio}}<p class="author-box-bio">{{bio}}</p>{{/if}}
          <a class="author-box-link" href="{{url}}">More by {{name}} &rarr;</a>
        </div>
      </aside>
    {{/foreach}}
    {{#if prev}}
      <nav class="post-nav">
        <div class="post-nav-item">
          <div class="post-nav-label">&larr; Previous</div>
          <a class="post-nav-title" href="{{prev.url}}">{{prev.title}}</a>
        </div>
        {{#if next}}
          <div class="post-nav-item next">
            <div class="post-nav-label">Next &rarr;</div>
            <a class="post-nav-title" href="{{next.url}}">{{next.title}}</a>
          </div>
        {{else}}<div></div>{{/if}}
      </nav>
    {{else}}
      {{#if next}}
        <nav class="post-nav">
          <div></div>
          <div class="post-nav-item next">
            <div class="post-nav-label">Next &rarr;</div>
            <a class="post-nav-title" href="{{next.url}}">{{next.title}}</a>
          </div>
        </nav>
      {{/if}}
    {{/if}}
  </article>
{{/post}}
</main>
